SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite:///instance/sirentracker.db

# Google Workspace OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_WORKSPACE_DOMAIN=yourdomain.org

# Email (Gmail SMTP via Workspace app-specific password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=alerts@yourdomain.org
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=SirenTracker <alerts@yourdomain.org>
